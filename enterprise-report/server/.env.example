# =========================================================================
#  server/.env  — Kopie von .env.example, dann ausfüllen. NICHT committen.
# =========================================================================

# --- MSSQL-Verbindung ----------------------------------------------------
# Server: "host"  ·  "host,1433"  ·  "host\INSTANZ"  (z. B. SQLPROD01\REPORTING)
MSSQL_SERVER=SQLPROD01\REPORTING
MSSQL_DATABASE=ERP_DWH

# Auth-Modus:  sql  (SQL-Login)  |  azure-ad  (Azure AD)  |  windows (LocalDB/lokal)
#   windows = Windows-Anmeldung über nativen Treiber (Backend läuft auf Windows).
#             Für SQL Server LocalDB der einzige Weg. Voraussetzungen:
#               - "Microsoft ODBC Driver 17/18 for SQL Server" installiert
#               - im Ordner server/:  npm install msnodesqlv8
#             User/Passwort entfallen dann (du meldest dich als Windows-User an).
MSSQL_AUTH=sql
MSSQL_USER=report_reader
MSSQL_PASSWORD=__bitte_setzen__
# MSSQL_ODBC_DRIVER=ODBC Driver 17 for SQL Server   # nur bei MSSQL_AUTH=windows

# Optional:
# MSSQL_PORT=1433
MSSQL_ENCRYPT=true            # Azure/Prod: true
MSSQL_TRUST_CERT=true         # self-signed Zertifikat lokal akzeptieren

# --- Connection-Pool (Skalierung bei vielen gleichzeitigen Nutzern) ------
# max:5 war der erste Engpass bei z. B. 200 parallelen Zugriffen. Default
# jetzt 30. Faustregel: an die max. erwartete Parallelität anpassen, aber
# unter dem MSSQL-Verbindungslimit bleiben.
# MSSQL_POOL_MAX=30
# MSSQL_POOL_MIN=0
# MSSQL_POOL_IDLE_MS=30000

# --- Server-Cache --------------------------------------------------------
# KPI-/Stammdaten sind für alle Nutzer identisch -> kurzlebiger Cache senkt
# die DB-Last drastisch. TTL in ms (Default 60000 = 60s); 0 schaltet ab.
# CACHE_TTL_MS=60000

PORT=3001

# --- Self-Service BI (Claude) -------------------------------------------
ANTHROPIC_API_KEY=sk-ant-__bitte_setzen__

# --- Stages & Transportwesen (dev/test/prod) ----------------------------
# Diese Instanz (eine pro Deployment):  dev | test | prod
# STAGE=dev
# Ziel-Branches je Stage (Transport pusht hierhin):
# STAGE_BRANCH_DEV=stage/dev
# STAGE_BRANCH_TEST=stage/test
# STAGE_BRANCH_PROD=stage/prod
# Für die UI muss auch das Frontend die Stage kennen:  VITE_STAGE=dev

# --- Verteiler / automatischer Versand ----------------------------------
# Ohne SMTP läuft der Versand als "dry-run" (kein realer Mailversand).
# Optionale Pakete im Ordner server:  npm install node-cron nodemailer exceljs
# SMTP_HOST=smtp.firma.de
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=reporting@firma.de
# SMTP_PASS=__bitte_setzen__
# MAIL_FROM=Controlling <reporting@firma.de>
# APP_URL=http://localhost:5180        # Basis für die Live-Links in den Mails

# --- Frontend gegen echte Quellen starten -------------------------------
#   VITE_DATA_SOURCE=mssql   (KPIs aus MSSQL statt Mock)
#   VITE_BI_SOURCE=claude    (Beirat via Claude statt Heuristik)
# Der Vite-Dev-Proxy (vite.config.js) leitet /api an dieses Backend.
